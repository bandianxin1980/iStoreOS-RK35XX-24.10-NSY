CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_DEVICE_rockchip_armv8_DEVICE_bd-one=y

# 关闭多设备编译（核心瘦身）
# CONFIG_TARGET_MULTI_PROFILE is not set
# CONFIG_TARGET_ALL_PROFILES is not set
# CONFIG_ALL_KMODS is not set

# 关闭调试信息（瘦身关键）
# CONFIG_DEVEL is not set
# CONFIG_KERNEL_DEBUG_INFO_BTF is not set

# 保留官方基础功能
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-quickstart=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-firewall=y

# 增加Cash科学上网插件
CONFIG_PACKAGE_luci-app-cash=y
CONFIG_PACKAGE_luci-i18n-cash-zh-cn=y
CONFIG_PACKAGE_cash-core=y

# 硬盘与交换机驱动（BD-ONE必须）
CONFIG_PACKAGE_kmod-ata-ahci=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-dsa-core=y

# 分区大小控制（固件大小约300MB）
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=256
